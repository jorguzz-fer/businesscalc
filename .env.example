# ==================================
# BusinessCalc v2 — Environment Variables Template
# ==================================
# Copy to .env and fill with real values for local development.
# NEVER commit .env to git.

# ---- Application ----
NODE_ENV=development
APP_URL=http://localhost:3000
PORT=3000

# ---- Database ----
# Local dev: use docker compose up -d postgres
DATABASE_URL=postgresql://businesscalc:businesscalc@localhost:5432/businesscalc?schema=public

# ---- Session / Auth ----
# Generate with: openssl rand -hex 64
SESSION_SECRET=CHANGE_ME_TO_64_BYTES_HEX

# ---- Encryption (Phase 3 — column-level AES-256-GCM) ----
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_TO_32_BYTES_HEX

# ---- Email (Resend) ----
# Get key from https://resend.com
RESEND_API_KEY=re_CHANGE_ME
EMAIL_FROM=BusinessCalc <noreply@yourdomain.com>

# ---- Logging ----
LOG_LEVEL=info

# ---- Optional (Phase 3+) ----
# SENTRY_DSN=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
